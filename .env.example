# Application
APP_NAME=KlyroAI
ENVIRONMENT=development
DEBUG=true

# Security — JWT signing (use a long random string, 32+ bytes for HS256)
SECRET_KEY=dev-only-change-me-use-openssl-rand-hex-32-in-prod

# JWT (optional)
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server (optional overrides)
# HOST=0.0.0.0
# PORT=8000

# Frontend paths (relative to backend/ when running uvicorn from backend/)
FRONTEND_STATIC_DIR=../frontend/static
FRONTEND_TEMPLATES_DIR=../frontend/templates

# SQLite (relative to backend/ unless absolute)
DATABASE_PATH=database.db

# OpenAI (embeddings + RAG chat) — paste your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# RAG chat (POST /api/v1/chat): vector chunks injected into the prompt
RAG_CHAT_TOP_K=5

# Vector backend: sqlite (local BLOB + numpy) or pinecone
VECTOR_BACKEND=sqlite

# Pinecone — pc = Pinecone(api_key=...); index = pc.Index("klyroai")
PINECONE_API_KEY=
PINECONE_INDEX_NAME=klyroai

# CORS — * allows embeddable widget from any origin; restrict in production (comma-separated URLs)
CORS_ALLOW_ORIGINS=*
