# Render.com: Set these in the Render dashboard > Environment tab
# For local dev, copy this file to .env and fill in values

# Application
APP_NAME=KlyroAI
ENVIRONMENT=development
DEBUG=true

# Security — JWT signing (use a long random string, 32+ bytes for HS256)
SECRET_KEY=dev-only-change-me-use-openssl-rand-hex-32-in-prod

# Frontend paths (relative to backend/ when running uvicorn from backend/)
FRONTEND_STATIC_DIR=../frontend/static
FRONTEND_TEMPLATES_DIR=../frontend/templates

# ── Database ────────────────────────────────────────────────────────────────
# Set DATABASE_URL for Postgres + pgvector (production).
# Leave blank to use SQLite for local dev.
# DATABASE_URL=postgresql://klyro:klyro@localhost:5432/klyro
DATABASE_PATH=database.db

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
RAG_CHAT_TOP_K=5

# Vector backend: sqlite | pgvector | pinecone
# Use sqlite locally without Postgres; pgvector when DATABASE_URL is set
VECTOR_BACKEND=sqlite

PINECONE_API_KEY=
PINECONE_INDEX_NAME=klyroai

CORS_ALLOW_ORIGINS=*

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
APP_BASE_URL=http://localhost:8000
